package day1prac.라이브러리만들기;

public class CodeRun {

	public void runThreeTimes(MyRunnable code) {
		for (int i = 1; i <= 3; i++) {
			code.run();
		}
	}

	public static void main(String[] args) {
		CodeRun codeRun = new CodeRun();
		codeRun.runThreeTimes(() -> {
			System.out.println("실행하고 싶은 코드");
		});
	}

}

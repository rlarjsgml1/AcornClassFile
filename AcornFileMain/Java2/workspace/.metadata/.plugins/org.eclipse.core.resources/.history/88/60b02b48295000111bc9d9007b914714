//
//Arrays.sort(배열정보);
//Arrays.sort(배열정보, Comparator c)

public class Acorn2 implements Comparable{
	String id;
	String name;
	int age;

	@Override
	public String toString() {
		return "Acorn2 [id=" + id + ", name=" + name + ", age=" + age + "]";
	}

	public String getId() {
		return id;
	}

	public String getName() {
		return name;
	}

	public int getAge() {
		return age;
	}

	public Acorn2(String id, String name, int age) {
		super();
		this.id = id;
		this.name = name;
		this.age = age;
	}

	public Acorn2() {
		// TODO Auto-generated constructor stub
	}

	@Override
	public int compareTo(Object o) {
		// TODO Auto-generated method stub
		
		Acorn2 a = (Acorn2) o;
		return this.age - a.age; //기준객체 - 비교객체
	}
}

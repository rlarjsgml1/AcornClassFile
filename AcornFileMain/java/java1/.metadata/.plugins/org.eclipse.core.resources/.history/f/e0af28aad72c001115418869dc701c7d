    // 선생님이 순찰하면서 현재 흡연자 인터럽트
    public void patrol() {
        if (gameOver) return;

        if (smokingNow && currentSmoker != null) {
            System.out.println("[선생님] 순찰 중! " + currentSmokerName + " 발견 시도!");
            currentSmoker.interrupt();
        } else {
            System.out.println("[선생님] 순찰 중... 아무도 안 피우는 것 같음");
        }
    }

    public Thread createSmoker(String name) {
        return new Thread(() -> {
            while (!gameOver) {
                try {
                    int wait = 1000 + random.nextInt(15000);
                    Thread.sleep(wait);
                } catch (InterruptedException e) {
                    // 이 구간은 피우는 중이 아니라 대기 중이므로 미적발 취급
                    System.out.println("[" + name + "] 대기 중 인터럽트 -> 미적발");
                }

                if (gameOver) break;

                smoke(name);
            }
        }, name);
    }

    public Thread createTeacher() {
        return new Thread(() -> {
            while (!gameOver) {
                try {
                    int wait = 1000 + random.nextInt(10000);
                    Thread.sleep(wait);
                } catch (InterruptedException e) {
                    System.out.println("[선생님] 대기 중 인터럽트");
                }

                if (gameOver) break;

                patrol();
            }
        }, "선생님");
    }

//Math 안에 두개의 함수   max, abs  가 있다.
// 두 개의 함수가 특정 클래스에 소속되어야 한다. 
// Math 클래스가 제공하는 기능
// Math 클래스를 사용하는 방법 ( method)


//static 메서드란?
//단순히 클래스에 소속된 메서드를 의미한다.(클래스를 사용하는 방법)
//사용법 : 클래스명.메서드() : 특정클래스에 소속되어있습니다

class MyMath{
       // 
       public static  int max( int a, int b){
          return  a>b?a:b;
       }       
       
       public static int abs( int a){
              if (a  < 0)
                  return  a*-1;
              else
                  return  a;
       }
       
}

class TestMain {
	public static void main(String[]args){
		int result = MyMath.max(5,4); //클래스명, 메서드()
		System.out.println(result);
	}
}